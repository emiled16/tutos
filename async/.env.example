# Async Inference Engine Configuration
HOST=0.0.0.0
PORT=8080

# Batching Configuration
MAX_BATCH_SIZE=32
BATCH_TIMEOUT_MS=50

# Queue Configuration
MAX_QUEUE_SIZE=1000
NUM_PRIORITY_LEVELS=3

# Rate Limiting
MAX_REQUESTS_PER_SECOND=100

# Timeouts
REQUEST_TIMEOUT_SECONDS=30
INFERENCE_TIMEOUT_SECONDS=10

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
