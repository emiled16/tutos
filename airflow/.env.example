# Airflow Configuration
AIRFLOW_HOME=./airflow_home
AIRFLOW__CORE__DAGS_FOLDER=./src/airflow/dags
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:///./airflow_home/airflow.db

# AWS / S3 Configuration
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your-ml-data-bucket

# Model Registry
MODEL_REGISTRY_URL=http://localhost:5000
MODEL_REGISTRY_API_KEY=your-registry-api-key

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# SMTP for Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
